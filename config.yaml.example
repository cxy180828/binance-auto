binance:
  api_key: "YOUR_API_KEY"
  secret: "YOUR_SECRET_KEY"
  testnet: true

trading:
  buy_amount_usdt: 100
  price_increase_threshold: 0.05
  trailing_stop_activation: 0.05
  trailing_stop_drop: 0.02
  time_stop_loss_minutes: 3
  volume_multiplier: 2.0
  cooldown_minutes: 5

blacklist:
  consecutive_losses: 2
  duration_minutes: 30

limits:
  max_daily_loss_usdt: 500
  max_daily_trades: 50
  max_open_positions: 10

feishu:
  webhook_url: ""

filter_list: []

scan_symbols: []

alpha:
  cache_minutes: 10

logging:
  level: INFO
  file: logs/trading.log

daily_summary_time: "20:00"

drop_alert:
  enabled: true
  level1_threshold: -0.05    # Warning level: -5%
  level2_threshold: -0.10    # Critical level: -10%
  feishu_webhook_url: ""     # Separate webhook for drop alerts
